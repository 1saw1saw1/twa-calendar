    {
      "parameters": {
        "jsCode": "const period = $input.first().json.period || 'Week';\nconst now = new Date();\nlet dateFrom = new Date();\nlet dateTo = new Date();\n\n// --- ВАШИ РАБОЧИЕ УСЛОВИЯ (НЕ МЕНЯЛИСЬ) ---\nif (period === 'Month') {\n    dateFrom = new Date(now.getFullYear(), now.getMonth(), 1);\n} else if (period === 'Week') {\n    dateFrom.setDate(now.getDate() - 7);\n    \n// --- ИСПРАВЛЕНИЕ ДЛЯ TODAY ---\n} else if (period === 'Today') {\n    // Устанавливаем dateFrom на начало сегодняшнего дня (00:00:00)\n    dateFrom.setHours(0, 0, 0, 0); \n    // dateTo остается текущим временем, так что dateFrom теперь точно МЕНЬШЕ, чем dateTo\n\n// --- ДЛЯ НОВОГО КАЛЕНДАРЯ (JSON-СТРОКА) ---\n} else if (period.startsWith('{') || period.includes('period')) {\n    try {\n        const calendarObj = JSON.parse(period);\n        dateFrom = new Date(calendarObj.date_from);\n        dateFrom.setHours(0, 0, 0, 0);\n        \n        dateTo = new Date(calendarObj.date_to);\n        dateTo.setHours(23, 59, 59, 999);\n    } catch (e) {\n        // На случай непредвиденной ошибки парсинга оставим текущую дату\n        dateFrom = new Date();\n        dateTo = new Date();\n    }\n\n// --- ДЛЯ СТАРЫХ КАСТОМНЫХ ДАТ ЧЕРЕЗ ПОДЧЕРКИВАНИЕ ---\n} else if (period.includes('_')) {\n    const dates = period.split('_');\n    dateFrom = new Date(dates[0]);\n    dateFrom.setHours(0, 0, 0, 0);\n    dateTo = dates[1] ? new Date(dates[1]) : new Date(dates[0]);\n    dateTo.setHours(23, 59, 59, 999);\n}\n\n// Превращаем даты в UNIX timestamp (в секундах)\nconst toUnix = (d) => Math.floor(d.getTime() / 1000);\n\nreturn {\n    json: {\n        crm_date_from: toUnix(dateFrom),\n        crm_date_to: toUnix(dateTo)\n    }\n};"
      },
