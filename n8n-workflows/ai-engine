    {
      "parameters": {
        "jsCode": "// 1. Получаем данные\nconst rawData = $input.first().json;\nconst orders = rawData.data || []; \n\n// 2. Группируем с нормализацией ключей\nconst grouped = {};\n\norders.forEach(order => {\n    if (order.items && Array.isArray(order.items)) {\n        order.items.forEach(item => {\n            // Нормализация имени: убираем лишние пробелы и приводим к одному регистру\n            // Это гарантирует, что \"Вінок\" и \"вінок \" попадут в одну группу\n            const rawName = item.product_name || \"Без назви\";\n            const name = rawName.trim(); \n            \n            if (!grouped[name]) {\n                grouped[name] = { n: name, p: 0, q: 0, r: 0 };\n            }\n            \n            // Используем Number() вместо parseFloat/parseInt для более строгого контроля\n            // и добавляем проверку, что это число, а не NaN\n            const p = Number(item.profit) || 0;\n            const q = Number(item.quantity) || 0;\n            const r = Number(item.amount) || 0;\n\n            grouped[name].p += p;\n            grouped[name].q += q;\n            grouped[name].r += r;\n        });\n    }\n});\n\n// 3. Формируем финальный массив\nconst finalProducts = Object.values(grouped);\n\n// 4. Добавляем итоговые показатели для AI, чтобы он не считал их сам\nconst totalRevenue = finalProducts.reduce((sum, item) => sum + item.r, 0);\nconst totalProfit = finalProducts.reduce((sum, item) => sum + item.p, 0);\n\nreturn [{\n    json: {\n        products: finalProducts,\n        kpi: {\n            total_profit: totalProfit.toFixed(2),\n            total_revenue: totalRevenue.toFixed(2),\n            avg_markup: totalRevenue > 0 ? ((totalProfit / totalRevenue) * 100).toFixed(2) : 0,\n            unique_count: finalProducts.length\n        }\n    }\n}];"
      },
